{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "cd skyright-forecaster && npm install && npm run build"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "cd skyright-forecaster && node dist/index.js",
    "restartPolicyMaxRetries": 5
  }
}
